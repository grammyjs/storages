{
	"name": "@grammyjs/storage-bun",
	"version": "2.6.0",
	"description": "Bun SQL storage for grammY library.",
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/bun#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "Satont <satontworldwide@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"src",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./src/mod.ts",
	"module": "./src/mod.ts",
	"types": "./src/mod.ts",
	"exports": {
		".": {
			"jsr": "./src/mod.ts",
			"types": "./src/mod.ts",
			"default": "./src/mod.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"test": "node --test __tests__/node.ts",
		"build": "pnpm typecheck"
	},
	"dependencies": {
		"grammy": "1"
	},
	"devDependencies": {
		"@types/bun": "1"
	},
	"jsrExclude": [
		"package.json"
	],
	"jsrInclude": [
		"src",
		"README.md",
		"LICENSE"
	]
}
