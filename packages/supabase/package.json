{
	"name": "@grammyjs/storage-supabase",
	"version": "2.6.0",
	"private": false,
	"description": "Supabase database storage",
	"keywords": [
		"bot",
		"grammy",
		"grammyjs",
		"session",
		"supabase",
		"telegram"
	],
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/supabase#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "waptik <me@waptik.xyz>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"jsr": "./src/mod.ts",
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"test": "echo \"Error: no tests found\"",
		"build": "tsdown"
	},
	"dependencies": {
		"@supabase/supabase-js": "2",
		"grammy": "1"
	},
	"devDependencies": {},
	"peerDependencies": {
		"@supabase/supabase-js": "2.110.8"
	},
	"jsrExclude": [
		"dist",
		"package.json"
	],
	"jsrInclude": [
		"src/",
		"README.md",
		"LICENSE"
	]
}
