{
	"name": "@grammyjs/storage-typeorm",
	"version": "2.5.1",
	"private": false,
	"description": "TypeORM storage for grammy library.",
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/typeorm#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "Satont <satontworldwide@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"test": "vitest",
		"build": "tsdown"
	},
	"devDependencies": {
		"@grammyjs/storage-utils": "workspace:*",
		"better-sqlite3": "12.11.1",
		"grammy": "1.44.0",
		"mongodb": "7.4.0",
		"mongodb-memory-server": "11.2.0",
		"typeorm": "1.0.0",
		"vite": "8.1.3",
		"vitest": "4.1.9"
	}
}
