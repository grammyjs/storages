{
	"name": "@grammyjs/storage-dynamodb",
	"version": "2.6.0",
	"private": false,
	"description": "DynamoDB session storage for grammY.",
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/dynamodb#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "grammyjs",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"test": "echo \"No tests found\"",
		"build": "tsdown"
	},
	"dependencies": {
		"@aws-sdk/lib-dynamodb": "3.1086.0"
	},
	"devDependencies": {
		"grammy": "catalog:"
	}
}
