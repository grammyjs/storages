{
	"name": "@grammyjs/storage-free",
	"version": "2.5.1",
	"private": false,
	"description": "Storage adapter for grammY's free sessions",
	"keywords": [
		"adapter",
		"bot",
		"free",
		"grammy",
		"session",
		"storage",
		"telegram"
	],
	"homepage": "https://github.com/grammyjs/storages/packages/free#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"build": "tsdown"
	},
	"devDependencies": {
		"grammy": "^1.44.0"
	}
}
