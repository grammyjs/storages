{
	"name": "@grammyjs/storage-prisma",
	"version": "2.5.1",
	"private": false,
	"description": "Prisma storage for grammY",
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/typeorm#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "Dani Haro <daniharopadul@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"test": "generate; prisma db push; vitest",
		"generate": "prisma generate",
		"build": "tsdown"
	},
	"devDependencies": {
		"@grammyjs/storage-utils": "workspace:*",
		"@prisma/client": "^7.8.0",
		"grammy": "^1.44.0",
		"prisma": "^7.8.0",
		"vite": "^8.1.3",
		"vitest": "^4.1.9"
	}
}
