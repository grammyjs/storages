generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model StringSession {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model PizzaSession {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
