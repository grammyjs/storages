generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model StringSession {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model PizzaSession {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
