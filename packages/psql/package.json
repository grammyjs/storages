{
	"name": "@grammyjs/storage-psql",
	"version": "2.6.0",
	"private": false,
	"description": "PSQL storage for grammY library.",
	"homepage": "https://github.com/grammyjs/storages/tree/main/packages/psql#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "Satont <satontworldwide@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"jsr": "./src/mod.ts",
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"test": "node __tests__/node.ts",
		"build": "tsdown"
	},
	"dependencies": {
		"grammy": "1",
		"pg": "8"
	},
	"devDependencies": {
		"@grammyjs/storage-utils": "workspace:*",
		"@types/pg": "8.20.0",
		"pg-mem": "3.0.14"
	},
	"jsrExclude": [
		"dist",
		"package.json"
	],
	"jsrInclude": [
		"src/",
		"README.md",
		"LICENSE"
	]
}
