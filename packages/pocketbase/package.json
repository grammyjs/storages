{
	"name": "@grammyjs/storage-pocketbase",
	"version": "2.6.0",
	"private": false,
	"description": "Pocketbase storage adapter for grammY",
	"keywords": [
		"adapter",
		"bot",
		"grammy",
		"pocketbase",
		"session",
		"storage",
		"telegram"
	],
	"homepage": "https://github.com/grammyjs/storages#readme",
	"bugs": {
		"url": "https://github.com/grammyjs/storages/issues"
	},
	"license": "MIT",
	"author": "ma <mobinaskarimail@protonmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grammyjs/storages.git"
	},
	"files": [
		"README.md",
		"dist",
		"package.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./dist/mod.cjs",
	"module": "./dist/mod.mjs",
	"types": "./dist/mod.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.cts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"typecheck": "tsc",
		"prebuild": "pnpm typecheck",
		"build": "tsdown"
	},
	"dependencies": {
		"grammy": "1",
		"pocketbase": "0.27"
	},
	"devDependencies": {
		"@grammyjs/storage-utils": "workspace:*"
	}
}
