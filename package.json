{
	"name": "@grammyjs/storages",
	"version": "2.5.2",
	"private": true,
	"repository": "grammyjs/storages",
	"workspaces": [
		"packages/*",
		"libs/*"
	],
	"scripts": {
		"prepare": "lefthook install || true",
		"build": "lerna run build",
		"test": "lerna run test",
		"dev": "lerna run dev --parallel",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"prepublish": "pnpm build",
		"publish": "lerna publish --no-private"
	},
	"devDependencies": {
		"@types/node": "24.12.2",
		"lefthook": "^1.11.13",
		"lerna": "8.1.2",
		"oxfmt": "latest",
		"oxlint": "latest",
		"rimraf": "6.1.3",
		"tsdown": "latest",
		"tsx": "4.7.1",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=26.0.0",
		"pnpm": ">=10.0.0"
	}
}
