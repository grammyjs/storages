{
	"name": "@grammyjs/storages",
	"version": "2.5.2",
	"private": true,
	"repository": "grammyjs/storages",
	"workspaces": [
		"packages/*",
		"libs/*"
	],
	"scripts": {
		"prepare": "lefthook install || true",
		"build": "lerna run build",
		"test": "lerna run test",
		"test:deno": "pnpm run --filter \"./packages/denokv\" test:deno",
		"dev": "lerna run dev --parallel",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"sync:jsr-versions": "node scripts/sync-jsr-versions.mjs",
		"prepublish": "pnpm sync:jsr-versions && pnpm build",
		"publish": "lerna publish --no-private",
		"publish:jsr": "./scripts/publish-jsr.sh"
	},
	"devDependencies": {
		"@types/node": "26.1.1",
		"lefthook": "2.1.10",
		"lerna": "9.0.7",
		"oxfmt": "0.60.0",
		"oxlint": "1.73.0",
		"tsdown": "0.22.7",
		"typescript": "7.0.2"
	},
	"engines": {
		"node": ">=26.0.0",
		"pnpm": ">=10.0.0"
	}
}
